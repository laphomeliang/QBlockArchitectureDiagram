        <mxCell id="AYyNZnRks3wTf1UOW9nu-28" connectable="0" parent="AYyNZnRks3wTf1UOW9nu-27" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" value="通过 QDesinger GUI 地址打开界面&amp;nbsp;" vertex="1">
