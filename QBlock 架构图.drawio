        <mxCell id="vm6xDNujBMLczH1im54--26" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;" value="API 进程" vertex="1">
          <mxGeometry height="100" width="560" x="-629" y="99" as="geometry" />
        </mxCell>
        <mxCell id="vm6xDNujBMLczH1im54--27" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2. 软件应用&amp;amp; API 进程控制关系&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;1、软件应用运行后，可调用 Pallas SDK 指令接口。&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;2、Pallas SDK 库文件接收到对应的指令，通过 2094 端口通道发送给 API 进程，从而控制机器人。&lt;/font&gt;&lt;/p&gt;" vertex="1">
