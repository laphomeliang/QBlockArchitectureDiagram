        <mxCell id="p8LCWhqM_mIbhJ-jUqgs-11" connectable="0" parent="p8LCWhqM_mIbhJ-jUqgs-10" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];" value="HTTP 通讯发送保存 QDesigner GUI 信息" vertex="1">
