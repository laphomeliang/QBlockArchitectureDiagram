        </mxCell>
        <mxCell id="iAPnYqF2oLcWZOgBj8bz-42" parent="HWiKMLakBleG0e2GBzOH-1" style="text;html=1;overflow=hidden;rounded=0;whiteSpace=wrap;fontSize=12;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;3. 自定义服务定义&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;1、&lt;/font&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(44, 62, 80); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Fira Sans&amp;quot;, &amp;quot;Droid Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, STHeiti, &amp;quot;Microsoft YaHei&amp;quot;, SimSun, sans-serif; font-size: 11px; font-weight: 600;&quot;&gt;JAKA_Service_config.ini 包含 AddOn 配置信息 (名称、端口、后端开发语言、功能描述)&lt;/span&gt;&lt;/p&gt;&lt;p&gt;2、&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(44, 62, 80); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Fira Sans&amp;quot;, &amp;quot;Droid Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, STHeiti, &amp;quot;Microsoft YaHei&amp;quot;, SimSun, sans-serif; font-size: 11px; font-weight: 600;&quot;&gt;JAKA_Service_config.ini&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(44, 62, 80); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Segoe UI&amp;quot;, Roboto, Oxygen, Ubuntu, Cantarell, &amp;quot;Fira Sans&amp;quot;, &amp;quot;Droid Sans&amp;quot;, &amp;quot;Helvetica Neue&amp;quot;, STHeiti, &amp;quot;Microsoft YaHei&amp;quot;, SimSun, sans-serif; font-size: 11px; font-weight: 600;&quot;&gt;&amp;nbsp;按规则打包上传到 JAKA App，JAKA App 部署自定义服务。&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 11px;&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;3、输入控制器地址加配置信息的端口号，可以打开 node-red 开发界面。&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 11px;&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;4、在&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 11px; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;node-red 开发界面可开发自定义服务的接口功能、自定义指令以及自定义界面。&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="269" width="393" x="206" y="897" as="geometry" />
        </mxCell>
