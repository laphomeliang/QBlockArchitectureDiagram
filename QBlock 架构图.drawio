        <mxCell id="Dp_1U9LGP05sUFZY-CT5-22" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="Flash 文件夹" vertex="1">
          <mxGeometry height="101" width="180" x="320" y="2109" as="geometry" />
        </mxCell>
        <mxCell id="Dp_1U9LGP05sUFZY-CT5-23" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;" value="&lt;span style=&quot;text-align: left;&quot;&gt;工程配置文件&lt;/span&gt;" vertex="1">
