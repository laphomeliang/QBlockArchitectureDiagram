        </mxCell>
        <mxCell id="HWiKMLakBleG0e2GBzOH-27" parent="HWiKMLakBleG0e2GBzOH-1" style="text;html=1;overflow=hidden;rounded=0;whiteSpace=wrap;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1. 外围设备 &amp;amp; 节卡 AddOn 插件&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;1、根据外围设备需求，节卡 AddOn 解决方案为&lt;span style=&quot;text-align: center; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;自定义网页和自定义指令&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;。&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2、节卡 AddOn 参考资料：&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;https://www.jaka.com/docs/guide/addOn/1.1-AboutAddOn.html&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="393" x="18" y="-1100" as="geometry" />
        </mxCell>
        <mxCell id="tnG8QT-j9YB55PpuZaY5-2" edge="1" parent="HWiKMLakBleG0e2GBzOH-1" source="HWiKMLakBleG0e2GBzOH-28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" target="tnG8QT-j9YB55PpuZaY5-0">
