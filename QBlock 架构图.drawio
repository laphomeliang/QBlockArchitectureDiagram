        <mxCell id="5FgAAv4vkr3eLdHrKdn7-29" parent="csML4lfEoVQIY2oHZMmy-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2. QKM+ 组件与状态图&amp;amp;图形程序&amp;amp;工程 QRL代码调用关系&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;1、在状态图中可导入 QKM+ 组件，导入后图形程序中可调用QKM+ 组件的配置与方法。&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;2、在工程中 QKM+ 组件会以代码的方式实例化，&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;通过 HTTP 通讯发送保存工程信息&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;。&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;3、根据 QBlock 信息，工程 QRL 代码引入 QKM+ 组件路径&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;。&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="490" width="350" x="860" y="-160" as="geometry" />
        </mxCell>
