        <mxCell id="-Gmm-LHjuqbipGvpE8D8-17" parent="PD4rw7al6KwJQ-wbAUHo-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;" value="QRL 工程文件" vertex="1">
