        <mxCell id="t0-THS3WoxtRY0N7hsyh-19" parent="h2vfg5xof5ICqQ1aPUKA-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;" value="QBlock 脚本文件" vertex="1">
          <mxGeometry height="60" width="120" x="225" y="-372" as="geometry" />
        </mxCell>
        <mxCell id="t0-THS3WoxtRY0N7hsyh-20" parent="h2vfg5xof5ICqQ1aPUKA-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="QRL 工程文件" vertex="1">
          <mxGeometry height="60" width="120" x="545" y="-372" as="geometry" />
        </mxCell>
        <mxCell id="t0-THS3WoxtRY0N7hsyh-21" parent="h2vfg5xof5ICqQ1aPUKA-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;状态图&amp;amp;图形程序&amp;amp;工程 QRL 代码关系&lt;/h1&gt;" vertex="1">
          <mxGeometry height="50" width="413" x="414" y="-1140" as="geometry" />
        </mxCell>
        <mxCell id="t0-THS3WoxtRY0N7hsyh-22" parent="h2vfg5xof5ICqQ1aPUKA-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1. 状态图&amp;amp;图形程序&amp;amp;工程 QRL代码生成关系&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;1、状态图是根据工程业务流程进行主流程状态制作。&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;2、图形程序是 QRL 代码的转译工具，根据每个状态业务进行图形拼接来实现 QRL 代码开发。&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;3、状态图结合图形程序得到 QBlock 的工程基础信息以及 QRL 代码，通过 HTTP 接口保存工程信息。&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;4、QBlock 服务接收保存工程的信息，会在 Flash 文件夹的工程目录文件夹中生成 QBlock 信息文件以及工程 QRL 代码文件。&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="490" width="350" x="850" y="-932" as="geometry" />
        </mxCell>
        <mxCell id="2Aq2KWs4EDmLawkT4UW3-0" edge="1" parent="h2vfg5xof5ICqQ1aPUKA-1" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="40" y="-240" as="sourcePoint" />
            <mxPoint x="1180" y="-240" as="targetPoint" />
          </mxGeometry>
        </mxCell>
