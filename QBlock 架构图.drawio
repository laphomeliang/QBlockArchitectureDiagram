        </mxCell>
        <mxCell id="p8LCWhqM_mIbhJ-jUqgs-3" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="应用层 (浏览器)" vertex="1">
          <mxGeometry height="220" width="640" x="100" y="90" as="geometry" />
        </mxCell>
        <mxCell id="p8LCWhqM_mIbhJ-jUqgs-4" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="rounded=0;whiteSpace=wrap;html=1;" value="QBlock 服务" vertex="1">
          <mxGeometry height="60" width="620" x="110" y="360" as="geometry" />
        </mxCell>
        <mxCell id="p8LCWhqM_mIbhJ-jUqgs-5" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="QBlock 界面" vertex="1">
          <mxGeometry height="180" width="620" x="110" y="120" as="geometry" />
        </mxCell>
        <mxCell id="p8LCWhqM_mIbhJ-jUqgs-6" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1. QDesigner GUI 编辑&lt;/h1&gt;&lt;p&gt;1、QDesigner 可编辑 GUI 界面，GUI 界面主要分三大类组件： &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;操作组件：如工程启停控制，机器人速度控制以及按钮控制，其中按钮控制可绑 QKM+ 组件实例方法做控制。&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;显示组件：可显示机器人实时信息如点位信息，全局变量信息，还可绑定 QKM+ 组件配置显示 QKM+ 组件实例的配置数据。&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;输入组件：用于配置 QKM+ 组件实例配置信息。&lt;/p&gt;&lt;p&gt;2、QDesigner 编辑完 GUI 界面，通过 HTTP 通讯发送 QDesigner GUI 信息进行保存。&lt;/p&gt;&lt;p&gt;3、QBlock 服务根据 QDesinger GUI 信息生成界面数据信息，保存到 QDesigner 数据库文件内&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="490" width="350" x="827" y="95" as="geometry" />
        </mxCell>
        <mxCell id="p8LCWhqM_mIbhJ-jUqgs-7" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="Card 文件夹" vertex="1">
          <mxGeometry height="101" width="170" x="330" y="470" as="geometry" />
        </mxCell>
        <mxCell id="p8LCWhqM_mIbhJ-jUqgs-8" parent="p8LCWhqM_mIbhJ-jUqgs-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;" value="&lt;span style=&quot;text-align: left;&quot;&gt;QDesigner 文件&lt;/span&gt;" vertex="1">
