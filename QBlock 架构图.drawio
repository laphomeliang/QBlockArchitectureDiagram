        <mxCell id="vm6xDNujBMLczH1im54--16" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1. 通过 Pallas SDK 应用开发&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;1、&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;我们可以对一些外围设备借助 SDK 进行软件开发，方便我们对外围设备配置。&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;2、对 API 进行的接口封装成 Pallas SDK 库文件。&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;3、各个平台应用可通过 Pallas SDK 库文件加载，第三方开发可实现控制机器人的软件应用。&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="200" width="350" x="21" y="-661" as="geometry" />
        </mxCell>
        <mxCell id="6MG9L8KIAUknAHEG-v9u-2" edge="1" parent="1" source="vm6xDNujBMLczH1im54--17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" target="vm6xDNujBMLczH1im54--4">
