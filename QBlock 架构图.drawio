        </mxCell>
        <mxCell id="q5GgPOaqNwxAD58q9Zxy-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="应用层 (Windows/Android)" vertex="1">
          <mxGeometry height="230" width="760" x="-770" y="620" as="geometry" />
        </mxCell>
        <mxCell id="q5GgPOaqNwxAD58q9Zxy-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="QBlock App /&amp;nbsp; Google 浏览器" vertex="1">
          <mxGeometry height="180" width="420" x="-740" y="650" as="geometry" />
        </mxCell>
        <mxCell id="q5GgPOaqNwxAD58q9Zxy-26" edge="1" parent="1" source="q5GgPOaqNwxAD58q9Zxy-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" target="q5GgPOaqNwxAD58q9Zxy-12">
