  <diagram name="插件" id="5wWiWReHc5PfujfFuU3R">
    <mxGraphModel grid="0" page="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="PD4rw7al6KwJQ-wbAUHo-0" />
        <mxCell id="PD4rw7al6KwJQ-wbAUHo-1" parent="PD4rw7al6KwJQ-wbAUHo-0" />
        <mxCell id="PD4rw7al6KwJQ-wbAUHo-3" parent="PD4rw7al6KwJQ-wbAUHo-1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;" value="应用层（各平台应用）" vertex="1">
          <mxGeometry height="97" width="221" x="-65" y="32" as="geometry" />
        </mxCell>
        <mxCell id="PD4rw7al6KwJQ-wbAUHo-6" parent="PD4rw7al6KwJQ-wbAUHo-1" style="text;html=1;overflow=hidden;rounded=0;whiteSpace=wrap;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;1. 外围设备&amp;amp;机器人关系&lt;/h1&gt;&lt;p&gt;1、外围设备通常指安装在机器人本体（控制器/关节/本体结构）之外，与机器人协同工作但物理上可分离的设备，如夹爪、升降柱、相机。&lt;/p&gt;&lt;p&gt;2、&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;机器人&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 11px; text-align: center; text-wrap-mode: nowrap; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;通过 I/O、串口、网线通讯来控制外围设备。&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 11px; text-align: center; text-wrap-mode: nowrap; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3、外围设备在控制操作之前需要对应的应用进行参数设置，应用 (驱动) 跟外围设备&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: 11px; text-align: center; text-wrap-mode: nowrap; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;通过 I/O、串口、网线通讯。&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="190" width="414" x="221" y="-211" as="geometry" />
        </mxCell>
        <mxCell id="rIgEtyHB5_Q_-m9b9tln-0" parent="PD4rw7al6KwJQ-wbAUHo-1" style="rounded=0;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;" value="外围设备" vertex="1">
          <mxGeometry height="121" width="163" x="-14" y="-211" as="geometry" />
        </mxCell>
        <mxCell id="rIgEtyHB5_Q_-m9b9tln-2" parent="PD4rw7al6KwJQ-wbAUHo-1" style="rounded=0;whiteSpace=wrap;html=1;" value="外围设备应用 (驱动)" vertex="1">
