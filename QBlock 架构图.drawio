        <mxCell id="2Aq2KWs4EDmLawkT4UW3-25" parent="h2vfg5xof5ICqQ1aPUKA-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#fff2cc;strokeColor=#d6b656;" value="QRL 工程文件" vertex="1">
          <mxGeometry height="60" width="120" x="567" y="470" as="geometry" />
        </mxCell>
        <mxCell id="2Aq2KWs4EDmLawkT4UW3-26" edge="1" parent="h2vfg5xof5ICqQ1aPUKA-1" source="2Aq2KWs4EDmLawkT4UW3-27" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;startArrow=classic;startFill=1;" target="2Aq2KWs4EDmLawkT4UW3-11">
