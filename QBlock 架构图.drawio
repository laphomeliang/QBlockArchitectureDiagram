  <diagram name="节卡 AddOn 插件" id="A1D-ZrNRDuBh8W_6IvjK">
    <mxGraphModel dx="2316" dy="1983" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" background="none" math="0" shadow="0">
      <root>
        <mxCell id="HWiKMLakBleG0e2GBzOH-0" />
        <mxCell id="HWiKMLakBleG0e2GBzOH-1" parent="HWiKMLakBleG0e2GBzOH-0" />
        <mxCell id="iAPnYqF2oLcWZOgBj8bz-104" parent="HWiKMLakBleG0e2GBzOH-1" style="rounded=0;whiteSpace=wrap;html=1;" value="" vertex="1">
