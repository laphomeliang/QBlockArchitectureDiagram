        </mxCell>
        <mxCell id="iAPnYqF2oLcWZOgBj8bz-25" parent="HWiKMLakBleG0e2GBzOH-1" style="text;html=1;overflow=hidden;rounded=0;whiteSpace=wrap;fontSize=12;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;5. 自定义指令&amp;amp;程序代码关系&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;1、程序代码中使用到自定义指令&lt;span style=&quot;background-color: transparent;&quot;&gt;。&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;2、保存代码后，自定义指令会根据自定义服务的逻辑生成指定的代码&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;。&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); text-align: justify;&quot;&gt;&lt;font face=&quot;Helvetica&quot; style=&quot;font-size: 11px;&quot;&gt;3、生成的指定代码会产生代码文件保存到控制器中&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); text-align: justify;&quot;&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;。&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" vertex="1">
