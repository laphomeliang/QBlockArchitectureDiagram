        <mxCell id="CNA3zSyAZR-AptDKkClA-41" parent="csML4lfEoVQIY2oHZMmy-1" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;" value="QRL 工程文件" vertex="1">
